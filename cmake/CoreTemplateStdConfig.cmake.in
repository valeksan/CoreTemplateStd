@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
include("${CMAKE_CURRENT_LIST_DIR}/CoreTemplateStdTargets.cmake")

foreach(_coretemplatestd_component ${CoreTemplateStd_FIND_COMPONENTS})
    if(_coretemplatestd_component STREQUAL "QtAdapter")
        if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/CoreTemplateStdQtAdapterTargets.cmake")
            find_dependency(QT NAMES Qt6 Qt5 COMPONENTS Core)
            find_dependency(Qt${QT_VERSION_MAJOR} COMPONENTS Core)
            include("${CMAKE_CURRENT_LIST_DIR}/CoreTemplateStdQtAdapterTargets.cmake")
            set(CoreTemplateStd_QtAdapter_FOUND TRUE)
        else()
            set(CoreTemplateStd_QtAdapter_FOUND FALSE)
        endif()
    else()
        set(CoreTemplateStd_${_coretemplatestd_component}_FOUND FALSE)
    endif()
endforeach()

check_required_components(CoreTemplateStd)
